{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build formulaspractica PDF in doc",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd doc/latex && latexmk -pdf -interaction=nonstopmode -halt-on-error -output-directory=.. formulaspractica.tex"
